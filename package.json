{
  "name": "commit-tree",
  "version": "1.0.0",
  "description": "Commit-history visualization library. Extends gitgraph.js with merge-commit indicators, deleted-branch markers, metadata tooltips and dynamic graph sizing.",
  "author": "Vipul Chaudhary",
  "contributors": [
    {
      "name": "Nicolas Carlo",
      "email": "nicolascarlo.espeon@gmail.com",
      "url": "https://github.com/nicoespeon/gitgraph.js (original gitgraph.js author)"
    },
    {
      "name": "Fabien Bernard",
      "email": "fabien0102@gmail.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quark-script/commit-tree.git"
  },
  "bugs": {
    "url": "https://github.com/quark-script/commit-tree/issues"
  },
  "keywords": [
    "git",
    "graph",
    "commit",
    "history",
    "svg",
    "visualization",
    "gitgraph"
  ],
  "homepage": "https://github.com/quark-script/commit-tree#readme",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "typings": "./lib/index.d.ts",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib",
    "src/commit-tree.css"
  ],
  "scripts": {
    "clean": "rm -rf ./lib",
    "build": "npm run clean && tsc",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
